{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AstralGalaxyMusicPlayer",
  "version": "2.0.0",
  "identifier": "top.maple-bamboo.astralgalaxy.musicplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Astral Galaxy Music",
        "width": 1313,
        "height": 766,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "icons/installer_side.bmp",
        "headerImage": "icons/installer_header.bmp",
        "displayLanguageSelector": true
      }
    }
  }
}